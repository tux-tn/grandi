{
	"compilerOptions": {
		"target": "ES2020",
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"strict": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"declaration": true,
		"sourceMap": false,
		"outDir": "./dist",
		"rootDir": ".",
		"types": ["node"]
	},
	"include": ["src/**/*.ts", "test/**/*.ts"]
}
